# LangSmith tracing — copy to .env and fill in your key
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<your-api-key>
LANGSMITH_PROJECT=iCrwd

# Chatwoot
CHATWOOT_BASE_URL=http://44.215.200.55:3000
CHATWOOT_BOT_TOKEN=<bot-token>
CHATWOOT_USER_TOKEN=<user-token>

# MongoDB (gigs live in crwds; default DB crwd_prod, use crwdDB for local docker)
MONGO_URI=mongodb://localhost:27017
# MONGO_DB=crwdDB
# Email/phone for user preloaded into graph state (lambda + tests)
# SUPPORT_CONTEXT_USER_EMAIL=android.user@yopmail.com
