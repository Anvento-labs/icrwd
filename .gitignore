# =============================================================================
# Monorepo .gitignore - chatwoot-fe | infra | lambdas
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist/
build/
out/
*.tsbuildinfo
*.d.ts

# -----------------------------------------------------------------------------
# AWS CDK (infra/)
# -----------------------------------------------------------------------------
.cdk.staging/
cdk.out/

# -----------------------------------------------------------------------------
# Python / Lambda (lambdas/)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
.env/
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
*.manifest

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# -----------------------------------------------------------------------------
# Logs & temp
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.tmp/
tmp/
temp/
*.tmp
*.temp
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db

# -----------------------------------------------------------------------------
# IDE & editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
.jest/

# -----------------------------------------------------------------------------
# Optional: lock files (uncomment if not committing)
# -----------------------------------------------------------------------------
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
